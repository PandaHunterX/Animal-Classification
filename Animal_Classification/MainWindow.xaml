<Window x:Class="Animal_Classification.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Animal_Classification"
        mc:Ignorable="d"
        Icon="/Assets/icon.ico"
        Title="Animal Classifier" Height="760" Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        x:Name="RootWindow">

    <Window.Resources>

        <!-- ══════════ LIGHT THEME DEFAULTS ══════════ -->
        <SolidColorBrush x:Key="BgWindow"          Color="#F2F5EE"/>
        <SolidColorBrush x:Key="BgCard"            Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgDropZone"        Color="#F0F4EB"/>
        <SolidColorBrush x:Key="BgResultCard"      Color="#F0FAE0"/>
        <SolidColorBrush x:Key="BorderCard"        Color="#DDE5D0"/>
        <SolidColorBrush x:Key="BorderDrop"        Color="#C8D8B8"/>
        <SolidColorBrush x:Key="BorderResult"      Color="#A8D060"/>
        <SolidColorBrush x:Key="TxtTitle"          Color="#1A2208"/>
        <SolidColorBrush x:Key="TxtMuted"          Color="#8A9A78"/>
        <SolidColorBrush x:Key="TxtPlaceholder"    Color="#AABAA0"/>
        <SolidColorBrush x:Key="Accent"            Color="#5A9E00"/>
        <SolidColorBrush x:Key="AccentHover"       Color="#6DBC00"/>
        <SolidColorBrush x:Key="AccentPressed"     Color="#447800"/>
        <SolidColorBrush x:Key="BtnOutlineFg"      Color="#5A9E00"/>
        <SolidColorBrush x:Key="BtnOutlineBg"      Color="Transparent"/>
        <SolidColorBrush x:Key="BtnOutlineHoverBg" Color="#EAF5D0"/>
        <SolidColorBrush x:Key="ProgressBg"        Color="#DDE8CC"/>
        <SolidColorBrush x:Key="Divider"           Color="#DDE5D0"/>
        <SolidColorBrush x:Key="GhCardBg"          Color="#F7FAF2"/>
        <SolidColorBrush x:Key="GhCardBorder"      Color="#DDE5D0"/>
        <SolidColorBrush x:Key="ToggleBg"          Color="#E2EDD5"/>
        <SolidColorBrush x:Key="ToggleFg"          Color="#4A8A00"/>
        <SolidColorBrush x:Key="TxtLabel"          Color="#6A8A58"/>

        <!-- Result fade-in + slide-up -->
        <Storyboard x:Key="PredictionAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.55"/>
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                             From="12" To="0" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Upload outline button -->
        <Style x:Key="UploadBtn" TargetType="Button">
            <Setter Property="Foreground"       Value="{DynamicResource BtnOutlineFg}"/>
            <Setter Property="Background"       Value="{DynamicResource BtnOutlineBg}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource BtnOutlineFg}"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="Height"           Value="40"/>
            <Setter Property="Width"            Value="190"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BtnOutlineHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="{DynamicResource BtnOutlineHoverBg}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="{DynamicResource AccentPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Predict filled button -->
        <Style x:Key="PredictBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Width"           Value="190"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GitHub hyperlink button -->
        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="Tb"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{DynamicResource Accent}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   TextDecorations="Underline"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tb" Property="Foreground" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Theme toggle pill button -->
        <Style x:Key="ToggleBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource ToggleBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ToggleFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Width"           Value="94"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="{DynamicResource BgWindow}">
        <Grid>

            <!-- Subtle accent glow (top-right) -->
            <Ellipse Width="260" Height="260"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-90,-70,0"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#125A9E00" Offset="0"/>
                        <GradientStop Color="#005A9E00"   Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ══════════ MAIN CARD ══════════ -->
            <Border Background="{DynamicResource BgCard}"
                    BorderBrush="{DynamicResource BorderCard}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Margin="28"
                    Padding="34,26">
                <!-- Grid: top content auto-sizes, middle spacer stretches, GitHub pinned to bottom -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ── Top content ── -->
                    <StackPanel Grid.Row="0">

                        <!-- Header row -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Image Source="/Assets/logo.png" Width="60" Height="60" Margin="0,0,4,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ANIMAL"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}"
                                           Opacity="0.85"/>
                                    <TextBlock Text="Classifier"
                                           FontFamily="Georgia"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TxtTitle}"
                                           Margin="0,-2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Button x:Name="ThemeToggleBtn"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource ToggleBtn}"
                                    Click="ThemeToggle_Click"
                                    Content="☀  LIGHT"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource Divider}" Margin="0,6,0,18"/>

                        <!-- Image drop zone -->
                        <Border x:Name="DropZone"
                                Height="250"
                                BorderBrush="{DynamicResource BorderDrop}"
                                BorderThickness="1.5"
                                CornerRadius="10"
                                Background="{DynamicResource BgDropZone}"
                                Margin="0,0,0,6"
                                ClipToBounds="True">
                            <Grid>
                                <StackPanel x:Name="PlaceholderPanel"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="🖼"
                                               FontSize="36"
                                               HorizontalAlignment="Center"
                                               Opacity="0.28"/>
                                    <TextBlock Text="No image uploaded"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{DynamicResource TxtPlaceholder}"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                                <Image x:Name="UploadedImage"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Filename label -->
                        <TextBlock x:Name="FileNameLabel"
                                   Text="—"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="{DynamicResource TxtMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,12">
                            <Button x:Name="UploadBtn"
                                    Content="↑  UPLOAD IMAGE"
                                    Style="{StaticResource UploadBtn}"
                                    Click="UploadImage_Click"
                                    Margin="0,0,10,0"/>
                            <Button x:Name="PredictBtn"
                                    Content="⚡  SCAN IMAGE"
                                    Style="{StaticResource PredictBtn}"
                                    Click="Predict_Click"/>
                        </StackPanel>

                        <!-- Loading panel -->
                        <StackPanel x:Name="LoadingPanel" Visibility="Collapsed" Margin="0,0,0,12">
                            <TextBlock Text="Analyzing image..."
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="{DynamicResource TxtMuted}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,6"/>
                            <ProgressBar x:Name="LoadingBar"
                                         Height="6"
                                         IsIndeterminate="True"
                                         Foreground="{DynamicResource Accent}"
                                         Background="{DynamicResource ProgressBg}"
                                         BorderThickness="0"/>
                        </StackPanel>

                        <!-- Result card -->
                        <Border x:Name="ResultCard"
                                Background="{DynamicResource BgResultCard}"
                                BorderBrush="{DynamicResource BorderResult}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="20,16"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="PredictionResult"
                                           FontFamily="Georgia"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}"
                                           TextAlignment="Center"
                                           Opacity="0">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform Y="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <TextBlock FontFamily="Consolas"
                                           FontSize="13"
                                           Foreground="{DynamicResource TxtMuted}"
                                           TextAlignment="Center"
                                           Margin="0,6,0,0">
                                    <Run x:Name="ConfidencePrefix" Text="Confidence:  "/>
                                    <Run x:Name="ConfidenceValue"  Text="" FontWeight="Bold" FontSize="14"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- Row 1: spacer (empty, stretches) -->

                    <!-- ── GitHub Profile Card — pinned to bottom ── -->
                    <StackPanel Grid.Row="2">
                        <Rectangle Height="1" Fill="{DynamicResource Divider}" Margin="0,0,0,14"/>

                        <Border Background="{DynamicResource GhCardBg}"
                                BorderBrush="{DynamicResource GhCardBorder}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="18,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Circular avatar: Ellipse with ImageBrush fill — true circle, no clipping artifacts -->
                                <Grid Grid.Column="0" Width="60" Height="60" Margin="0,0,16,0">
                                    <!-- Accent ring behind -->
                                    <Ellipse Width="60" Height="60"
                                             StrokeThickness="2.5">
                                        <Ellipse.Stroke>
                                            <DynamicResource ResourceKey="Accent"/>
                                        </Ellipse.Stroke>
                                    </Ellipse>
                                    <!-- Image clipped natively to ellipse shape via Fill -->
                                    <Ellipse Width="54" Height="54"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <ImageBrush x:Name="AvatarBrush"
                                                        Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>

                                <!-- Label / Name / Link -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="TRAINED &amp; DEPLOYED BY"
                                               FontFamily="Consolas"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TxtLabel}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="PandaHunterX"
                                               FontFamily="Georgia"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TxtTitle}"
                                               Margin="0,0,0,3"/>
                                    <Button Content="github.com/PandaHunterX"
                                            Style="{StaticResource LinkBtn}"
                                            HorizontalAlignment="Left"
                                            Click="GitHubLink_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
